# Docker environment overrides
# Copy to conference_agent/.env.docker and reference with: docker compose --env-file conference_agent/.env.docker up -d

# ── Service ports ──────────────────────────────────────────────────────────
BACKEND_PORT=8001
FRONTEND_PORT=5173
LITELLM_PROXY_PORT=4000
SCRAPLING_MCP_PORT=8017
POSTGRES_PORT=5432

# ── CORS ───────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://frontend:5173,http://localhost:5173

# ── Database ───────────────────────────────────────────────────────────────
POSTGRES_USER=litellm
POSTGRES_PASSWORD=litellm
POSTGRES_DB=litellm