# ─────────────────────────────────────────
# Conference Discovery — environment variables
# ─────────────────────────────────────────
# Copy this file to .env and fill in your actual keys:
#   cp .env.example .env
# NEVER commit real secrets to git (.env is gitignored).

# Mistral LLM API key
# Get yours at: https://console.mistral.ai/
MISTRAL_API_KEY=

# Exa Search API key (required for conference discovery)
# Get yours at: https://exa.ai
EXA_API_KEY=

# LiteLLM Proxy Configuration
# Must match master_key in proxy_config.yaml (default: sk-1234)
LITELLM_PROXY_API_KEY=sk-1234
LITELLM_PROXY_API_BASE=http://localhost:4000
